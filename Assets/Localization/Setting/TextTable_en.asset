  - m_Id: 113318622060544
    m_Localized: Back to Title
    m_Metadata:
      m_Items: []
  - m_Id: 115541162778624
    m_Localized: "I am the master of this mansion, Boss Cass. \nNice to meet you.\nPlease
      protect this mansion from all kinds of filth!"
    m_Metadata:
      m_Items: []
  - m_Id: 8699891567484928
    m_Localized: Nod. (boing)
    m_Metadata:
      m_Items: []
  - m_Id: 8700666448371712
    m_Localized: I hear you're good at magic.
    m_Metadata:
      m_Items: []
  - m_Id: 11613184942596096
    m_Localized: Bang!!!
    m_Metadata:
      m_Items: []
  - m_Id: 11397062829531136
    m_Localized: It seems bubbles have come!
    m_Metadata:
      m_Items: []
  - m_Id: 11397062842114048
    m_Localized: Wow! The mansion has become dirty...
    m_Metadata:
      m_Items: []
  - m_Id: 11397062842114049
    m_Localized: They've appeared again!
    m_Metadata:
      m_Items: []
  - m_Id: 11397062842114050
    m_Localized: This time, try driving them away with wind!
    m_Metadata:
      m_Items: []
  - m_Id: 11397062842114051
    m_Localized: Blow the wind into the bubble!
    m_Metadata:
      m_Items: []
  - m_Id: 11397062842114052
    m_Localized: Now! Breathe!!
    m_Metadata:
      m_Items: []
  - m_Id: 11397062842114053
    m_Localized: Well done.
    m_Metadata:
      m_Items: []
  - m_Id: 11397062842114054
    m_Localized: It seems bubble have come again!
    m_Metadata:
      m_Items: []
  - m_Id: 11397062842114055
    m_Localized: "Attract the bubbles and clap them down in one go!\u3000"
    m_Metadata:
      m_Items: []
  - m_Id: 11397062842114056
    m_Localized: Hold your hands!
    m_Metadata:
      m_Items: []
  - m_Id: 11397062842114057
    m_Localized: ' Clap your hands!! Now!!'
    m_Metadata:
      m_Items: []
  - m_Id: 11397062842114058
    m_Localized: ' Okay! We defeated it! We managed to keep clean!'
    m_Metadata:
      m_Items: []
  - m_Id: 11397062842114059
    m_Localized: 'Keep up the good work! Ho ho ho! '
    m_Metadata:
      m_Items: []
  - m_Id: 11921094477864960
    m_Localized: "\u30C9\u30FB\u30D0\u30D6\u30EB"
    m_Metadata:
      m_Items: []
  - m_Id: 11921094494642176
    m_Localized: "\u30C9\u30FB\u3061\u3073\u30D0\u30D6\u30EB"
    m_Metadata:
      m_Items: []
  - m_Id: 11921094494642177
    m_Localized: "\u30C9\u30FB\u3088\u308D\u3044\u30D0\u30D6\u30EB"
    m_Metadata:
      m_Items: []
  - m_Id: 11921094494642178
    m_Localized: "\u6C5A\u308C\u305F\u30D0\u30D6\u30EB\u3002\r\n\u5272\u308C\u308B\u3068\u6C5A\u308C\u3092\u6492\u304D\u6563\u3089\u3057\u3066\u3001\u5C4B\u6577\u3092\u3088\u3054\u3059\u3002\r\n\u9B54\u6CD5\u306E\u624B\u3067\u6D44\u5316\u3057\u3066\u5012\u305D\u3046\uFF01\r"
    m_Metadata:
      m_Items: []
  - m_Id: 11921094494642179
    m_Localized: "\u30C9\u30FB\u30D0\u30D6\u30EB\u3088\u308A\u4E8C\u56DE\u308A\u5C0F\u3055\u3044\u30D0\u30D6\u30EB\u3002\r\n\u3059\u3070\u3057\u3063\u3053\u3044\u306E\u3067\u6C17\u3092\u3064\u3051\u3088\u3046\u3002"
    m_Metadata:
      m_Items: []
  - m_Id: 11921094494642180
    m_Localized: "\u3088\u308D\u3044\u3092\u8EAB\u306B\u307E\u3068\u3063\u305F\u30C9\u30FB\u30D0\u30D6\u30EB\u3002\r\n\u306A\u3093\u3068\u30AF\u30E9\u30C3\u30D7\u304C\u52B9\u304B\u306A\u3044\u305E\u3002\r\n\u606F\u3092\u5439\u3044\u3066\u3001\u3088\u308D\u3044\u3092\u5439\u304D\u98DB\u3070\u305B\uFF01"
    m_Metadata:
      m_Items: []
  references:
